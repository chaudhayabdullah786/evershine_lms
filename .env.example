# Local development environment variables
# Copy this to .env and fill in your actual values.
# NEVER commit the .env file to GitHub.

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DATABASE_URL="mysql://username:password@host:3306/dbname"
DIRECT_URL="mysql://username:password@host:3306/dbname"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:5000"

# ── External Services ─────────────────────────────────────────────────────────
# Image hosting (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="evershaheen/students"

# Email service (Resend)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_NAME="Evershaheen Academy"

# Rate limiting / Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Security — required for Vercel crons (Authorization: Bearer <CRON_SECRET>)
# Schedules in vercel.json: fee-penalties, teacher-attendance, fee-reminder, birthday-check
CRON_SECRET="your-cron-secret-here"

# ── App Config ────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:5000"
NEXT_PUBLIC_APP_NAME="Evershaheen Academy LMS"
# Hide legacy Class/Timetable nav when true (default). Set false during parallel-run migration.
NEXT_PUBLIC_ACADEMIC_ENGINE_PRIMARY="true"
# Allow legacy Class attendance/timetable POST for admins (default: blocked when engine is primary)
# LEGACY_API_ENABLED="true"
# Include demo section + enrollments when running npm run db:seed:academic (default: on)
# ACADEMIC_SEED_DEMO="false"
