# Evershaheen Academy LMS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in every value.
# 3. NEVER commit .env to version control.
#
# For Hostinger production: set each variable in
#   hPanel → Node.js Web App → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL — Hostinger) ─────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Hostinger example: mysql://u668799501_user:YourPass@127.0.0.1:3306/u668799501_lms
DATABASE_URL="mysql://user:password@127.0.0.1:3306/database_name"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret with: openssl rand -hex 32
NEXTAUTH_SECRET="your-secret-here"
# Development: http://localhost:5000
# Production:  https://yourdomain.com
NEXTAUTH_URL="http://localhost:5000"

# ── External Services ─────────────────────────────────────────────────────────
# Image/document upload hosting (Cloudinary). Required when Cloudinary-backed
# uploads are enabled. Run REQUIRE_CLOUDINARY=true npm run check:env before
# deploying upload-dependent releases.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="evershaheen"
# REQUIRE_CLOUDINARY="true"

# Email service (Resend)
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_NAME="Evershaheen Academy"

# Rate limiting / Cache (Upstash Redis — optional)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Security — required for scheduled cron jobs (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET="your-cron-secret-here"

# ── App Config ────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:5000"
NEXT_PUBLIC_APP_NAME="Evershaheen Academy LMS"
# Hide legacy Class/Timetable nav when true (default). Set false during parallel-run migration.
NEXT_PUBLIC_ACADEMIC_ENGINE_PRIMARY="true"
# Allow legacy Class attendance/timetable POST for admins (default: blocked when engine is primary)
# LEGACY_API_ENABLED="true"
# Include demo section + enrollments when running npm run db:seed:academic (default: on)
# ACADEMIC_SEED_DEMO="false"
