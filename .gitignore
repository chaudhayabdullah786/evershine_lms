# ═══════════════════════════════════════════════════════════════════════════════
# 14. UPLOADS & USER DATA — Never commit user-generated content
# ═══════════════════════════════════════════════════════════════════════════════
/public/uploads/*
!/public/uploads/.gitkeep
/uploads/
/temp/
/tmp/
*.zip
