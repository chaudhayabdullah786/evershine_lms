# ═══════════════════════════════════════════════════════════════════════════════
# Evershine Academy LMS — Production .gitignore
# Last updated: 2026-06-20
# Policy: Track ONLY production source code, configs, public assets, and docs.
#         Exclude all secrets, build artifacts, dev tools, raw media, and scratch files.
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1. Dependencies ───────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── 2. Build & Runtime Artifacts ──────────────────────────────────────────────
.next/
out/
build/
dist/
.vercel/
*.tsbuildinfo
next-env.d.ts
.turbo/
build-output.txt

# ── 3. Security & Secrets ────────────────────────────────────────────────────
# CRITICAL: No credentials, API keys, passwords, or connection strings in VCS
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
secrets/
*.pem
*.key
*.pfx
*.p12
credentials.json
service-account.json
oauth.json

# ── 4. Database ───────────────────────────────────────────────────────────────
/prisma/*.db
/prisma/*.db-journal
/prisma/*.sqlite
/prisma/*.sqlite-journal
*.sqlite
*.sqlite3
dump.sql
backup.sql
production-mysql-schema.sql
prisma-init-log.txt

# ── 5. Scratch files ──────────────────────────────────────────
create

# ── 6. Test & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
.coverage
htmlcov/
.pytest_cache/
test-results/
test-report.html
*.lcov

# ── 6. IDE & Editor Configs ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace
.code-workspace

# ── 7. OS Files ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride

# ── 8. Logs & Cache ──────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/
debug_fee.log
.cache/
.eslintcache
.stylelintcache
__pycache__/

# ═══════════════════════════════════════════════════════════════════════════════
