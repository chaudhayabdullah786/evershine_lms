{
  "name": "evershine-lms",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "RAYON_NUM_THREADS=1 TOKIO_WORKER_THREADS=1 next build --webpack",
    "postbuild": "node scripts/postbuild-sync.js",
    "setup:pwa-icons": "node scripts/setup-pwa-icons.js",
    "start": "node server.js",
    "test": "vitest run",
    "test:academic": "vitest run tests/academic/",
    "test:academic:api": "playwright test --project=academic-api",
    "test:visual": "playwright test",
    "export:smoke": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/test-document-generation.ts",
    "test:export": "npx playwright test tests/export-color-bw.spec.ts",
    "playwright:install": "playwright install --with-deps",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node -r tsconfig-paths/register --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts",
    "db:create-accountant": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/create-accountant.ts",
    "db:seed:academic": "ts-node -r tsconfig-paths/register --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/seed-academic-engine.ts",
    "db:migrate:academic": "ts-node -r tsconfig-paths/register --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/migrate-legacy-academic.ts",
    "db:migrate:academic:dry": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}' scripts/migrate-legacy-academic.ts --dry-run",
    "db:setup:academic": "npm run db:seed:academic && npm run db:migrate:academic",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@hookform/resolvers": "^5.2.2",
    "@node-rs/argon2": "^1.7.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.101.0",
    "@upstash/ratelimit": "^1.2.1",
    "@upstash/redis": "^1.34.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.76.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "resend": "^3.4.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^26.0.0",
    "playwright": "^1.44.0",
    "prisma": "^5.22.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.7"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "description": "Enterprise-grade Academy Management System — multi-shift academics, institutional finance, branded reporting, and recruitment pipeline for educational institutions.",
  "keywords": [
    "academy-management",
    "school-erp",
    "lms",
    "next.js",
    "prisma",
    "education",
    "attendance",
    "fee-management",
    "multi-campus",
    "rbac"
  ],
  "author": "Ibadat Ali <https://github.com/Ibadat-Ali86>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
